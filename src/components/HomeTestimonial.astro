---
interface Props {
	imageSrc: string;
	imageAlt?: string;
	quote: string;
	name: string;
	location?: string;
	rating?: number;
}

const { imageSrc, imageAlt, quote, name, location, rating = 5 } = Astro.props;

const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.5;
const starsLabel = `${rating} out of 5 stars`;
const stars = '★'.repeat(fullStars) + (hasHalf ? '½' : '');
---

<article class="home-testimonial">
	<img
		class="home-testimonial__image"
		src={imageSrc}
		alt={imageAlt || ''}
		loading="lazy"
		decoding="async"
	/>
	<div class="home-testimonial__quote">
		<p class="home-testimonial__stars" aria-label={starsLabel}>{stars}</p>
		<blockquote>
			<p>{quote}</p>
			<cite>- {name}{location ? `, ${location}` : ''}</cite>
		</blockquote>
	</div>
</article>
