---
interface Props {
	imageSrc: string;
	imageAlt?: string;
	quote: string;
	name: string;
	location?: string;
	rating?: number;
}

const { imageSrc, imageAlt, quote, name, location, rating = 5 } = Astro.props;

const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.5;
const stars = '★'.repeat(fullStars) + (hasHalf ? '½' : '');
---

<article class="about-review-card">
	<img
		class="about-review-card__image"
		src={imageSrc}
		alt={imageAlt || ''}
		loading="lazy"
		decoding="async"
	/>

	<div class="about-review-card__content">
		<p>{quote}</p>
		<p class="about-review-card__meta">{stars} - {name}{location ? `, ${location}` : ''}</p>
	</div>
</article>
