---
interface Props {
	itemClass: string;
	contentClass: string;
	summary: string;
	open?: boolean;
}

const { itemClass, contentClass, summary, open = false } = Astro.props;
---

<details class={itemClass} open={open}>
	<summary>{summary}</summary>
	<div class={contentClass}>
		<slot />
	</div>
</details>
