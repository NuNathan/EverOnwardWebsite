---
import AccordionItem from '../../components/AccordionItem.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import VirtualProcessCard from '../../components/VirtualProcessCard.astro';
import VirtualTestimonialCard from '../../components/VirtualTestimonialCard.astro';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { fetchStrapi, strapiMediaUrl } from '../../lib/strapi';
import '../../styles/cta.css';
import '../../styles/virtual-training.css';

const { data: page } = await fetchStrapi('/virtual-training-page', {
	populate: 'heroBackgroundImage,heroCardImage,detailsBackgroundImage,detailsImage,detailItems,testimonialsBackgroundImage,reviews,reviews.image,processSteps,ctaBackgroundImage',
});

const heroBackground = strapiMediaUrl(page?.heroBackgroundImage?.url);
const heroCardImage = strapiMediaUrl(page?.heroCardImage?.url);
const detailsBackground = strapiMediaUrl(page?.detailsBackgroundImage?.url);
const detailsImage = strapiMediaUrl(page?.detailsImage?.url);
const testimonialsBackground = strapiMediaUrl(page?.testimonialsBackgroundImage?.url);
const ctaBackground = strapiMediaUrl(page?.ctaBackgroundImage?.url);
---

<SiteLayout
	title="Virtual Training | Ever Onward Canine"
	description="Virtual dog training with Ever Onward Canine."
>
	<section class="virtual-hero" aria-labelledby="virtual-hero-title">
		<div class="virtual-hero__frame">
			<img
				class="virtual-hero__background"
				src={heroBackground}
				alt=""
				loading="eager"
				decoding="async"
			/>

			<div class="virtual-hero__overlay">
				<div class="virtual-hero__content">
					<p>{page?.heroSubtitle}</p>
					<h1 id="virtual-hero-title">{page?.heroHeading}</h1>
				</div>

				<aside class="virtual-hero-card" aria-label="Virtual training note">
					{heroCardImage && (
						<img
							class="virtual-hero-card__image"
							src={heroCardImage}
							alt=""
							loading="eager"
							decoding="async"
						/>
					)}

					<div class="virtual-hero-card__body">
						<img
							class="virtual-hero-card__icon"
							src="/images/general/Paw.webp"
							alt=""
							loading="lazy"
							decoding="async"
						/>
						<p>{page?.heroCardText}</p>
					</div>
				</aside>
			</div>
		</div>
	</section>

	<section class="virtual-intro" aria-label="Virtual training overview">
		<div class="virtual-intro__content">
			<h2>{page?.introHeading}</h2>
			<p>{page?.introBody}</p>
		</div>
	</section>

	<section class="virtual-details" aria-labelledby="virtual-details-title">
		{detailsBackground && (
			<img
				class="virtual-details__background"
				src={detailsBackground}
				alt=""
				loading="lazy"
				decoding="async"
			/>
		)}

		<div class="virtual-details__card">
			<div class="virtual-details__content">
				<h2 id="virtual-details-title">{page?.detailsHeading}</h2>

				<div class="virtual-details__accordion" aria-label="Virtual training details">
					{page?.detailItems?.map((item: any) => (
						<AccordionItem
							itemClass="virtual-detail-item"
							contentClass="virtual-detail-item__content"
							summary={item.summary}
						>
							<p>{item.text}</p>
						</AccordionItem>
					))}
				</div>
			</div>

			{detailsImage && (
				<img
					class="virtual-details__image"
					src={detailsImage}
					alt=""
					loading="lazy"
					decoding="async"
				/>
			)}
		</div>
	</section>

	<section class="virtual-testimonials" aria-label="Client testimonials">
		{testimonialsBackground && (
			<img
				class="virtual-testimonials__background"
				src={testimonialsBackground}
				alt=""
				loading="lazy"
				decoding="async"
			/>
		)}

		<div class="virtual-testimonials__viewport">
			<div class="virtual-testimonials__track" data-virtual-testimonial-track>
				{page?.reviews?.map((review: any) => (
					<VirtualTestimonialCard
						quote={review.quote}
						name={review.name}
						location={review.location}
						rating={review.rating}
					/>
				))}
			</div>

			<div class="virtual-testimonials__controls" aria-label="Testimonial controls">
				<button type="button" data-virtual-testimonial-prev aria-label="Previous testimonial">
					&larr;
				</button>
				<button type="button" data-virtual-testimonial-next aria-label="Next testimonial">
					&rarr;
				</button>
			</div>
		</div>
	</section>

	<script>
		const testimonialTrack = document.querySelector('[data-virtual-testimonial-track]');
		const testimonialPrev = document.querySelector('[data-virtual-testimonial-prev]');
		const testimonialNext = document.querySelector('[data-virtual-testimonial-next]');

		if (testimonialTrack && testimonialPrev && testimonialNext) {
			const testimonialCards = Array.from(testimonialTrack.children);
			let testimonialIndex = 0;

			const scrollToTestimonial = (index: number, behavior: ScrollBehavior = 'smooth') => {
				const card = testimonialCards[index] as HTMLElement;

				if (!card) {
					return;
				}

				testimonialTrack.scrollTo({
					left: card.offsetLeft - (testimonialTrack as HTMLElement).offsetLeft,
					behavior,
				});
			};

			testimonialPrev.addEventListener('click', () => {
				testimonialIndex =
					(testimonialIndex - 1 + testimonialCards.length) % testimonialCards.length;
				scrollToTestimonial(testimonialIndex);
			});

			testimonialNext.addEventListener('click', () => {
				testimonialIndex = (testimonialIndex + 1) % testimonialCards.length;
				scrollToTestimonial(testimonialIndex);
			});

			window.addEventListener('resize', () => scrollToTestimonial(testimonialIndex, 'auto'));
		}
	</script>

	<section class="virtual-process" aria-labelledby="virtual-process-title">
		<div class="virtual-process__intro">
			<div>
				<p class="virtual-process__eyebrow">{page?.processEyebrow}</p>
				<h2 id="virtual-process-title">{page?.processHeading}</h2>
			</div>

			<div class="virtual-process__copy">
				<p>{page?.processBody}</p>
			</div>
		</div>

		<div class="virtual-process__steps" aria-label="Virtual training process steps">
			{page?.processSteps?.map((step: any) => (
				<VirtualProcessCard title={step.title} text={step.text} />
			))}
		</div>
	</section>

	<CtaBanner
		id="virtual-cta-title"
		title={page?.ctaHeading || ''}
		imageSrc={ctaBackground}
		eyebrow={page?.ctaEyebrow}
		buttonHref={page?.ctaButtonLink}
		buttonText={page?.ctaButtonText}
		flush
	/>
</SiteLayout>
