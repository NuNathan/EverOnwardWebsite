const processSteps = [
	'Step One',
	'Step Two',
	'Step Three',
	'Step Four',
].map((title) => ({
	title,
	text: 'Duis non quam et nisi tincidunt fermentum. Pellentesque habitant morbi tristique senectus et netus et malesuada.',
