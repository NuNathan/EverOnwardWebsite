	},
	{
		summary: 'What to Expect',
		text: 'Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Sessions are structured, practical, and tailored to your dog.',
	},
	{
		summary: 'Investment',
		text: 'Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.',
	},
];

const testimonials = [
	{
		quote:
			'Porro dolor amet tetur velit modi tempora incidunt ut magnam alisuam ad mini veniam nostrum exercita tionem corporis suscipit nisi ut aliquid commo autem.',
		author: '- John Smith, Calgary',
	},
	{
		quote:
			'Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur.',
		author: '- Jane Doe, Calgary',
	},
	{
		quote:
			'Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.',
		author: '- Alex Taylor, Calgary',
	},
