		imageAlt: 'Small white dog sitting in a park.',
		text: reviewText,
		meta: 'â˜…â˜…â˜…â˜…â˜… - Jane Doe, Calgary',
	},
	{
		imageSrc: '/images/home/stylish-girl-sunny-field-with-dog.webp',
		imageAlt: 'Person sitting with a dog near water.',
