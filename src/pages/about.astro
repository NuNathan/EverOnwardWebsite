---
import AboutCtaCard from '../components/AboutCtaCard.astro';
import AboutReviewCard from '../components/AboutReviewCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { fetchStrapi, strapiMediaUrl } from '../lib/strapi';
import '../styles/about.css';

const { data: page } = await fetchStrapi('/about-page', {
	populate: 'heroImage,founderImage,reviews,reviews.image,ctaBandImage,ctaCards',
});

const heroImage = strapiMediaUrl(page?.heroImage?.url);
const founderImage = strapiMediaUrl(page?.founderImage?.url);
const ctaBandImage = strapiMediaUrl(page?.ctaBandImage?.url);
---

<SiteLayout
	title="About | Ever Onward Canine"
	description="Learn more about Ever Onward Canine."
>
	<section class="about-hero" aria-label="About Ever Onward Canine">
		<div class="about-hero__frame">
			<img
				class="about-hero__image"
				src={heroImage}
				alt=""
				loading="eager"
				decoding="async"
			/>

			<div class="about-hero__overlay">
				<h1>{page?.heroHeading}</h1>
			</div>
		</div>
	</section>

	<section class="about-founder" aria-labelledby="about-founder-title">
		<div class="about-founder__media">
			<div class="about-founder__image-frame">
				<img
					class="about-founder__image"
					src={founderImage}
					alt=""
					loading="lazy"
					decoding="async"
				/>

				<img
					class="about-founder__submark"
					src="/images/general/EOC-Submark-B-Mint.webp"
					alt=""
					loading="lazy"
					decoding="async"
				/>
			</div>

			{page?.founderCaption && <p class="about-founder__caption">{page.founderCaption}</p>}
		</div>

		<div class="about-founder__content">
			<p class="about-founder__eyebrow">{page?.founderEyebrow}</p>
			<h2 id="about-founder-title">{page?.founderHeading}</h2>
			<Fragment set:html={page?.founderBody} />
		</div>
	</section>

	<section class="about-reviews" aria-label="Client reviews">
		<div class="about-reviews__track" id="about-reviews-track">
			{page?.reviews?.map((review: any) => (
				<AboutReviewCard
					imageSrc={strapiMediaUrl(review.image?.url)}
					imageAlt={review.imageAlt}
					quote={review.quote}
					name={review.name}
					location={review.location}
					rating={review.rating}
				/>
			))}
		</div>

		<div class="about-reviews__controls" aria-label="Review controls">
			<button type="button" data-about-review-scroll="prev" aria-label="Previous review">
				&larr;
			</button>
			<button type="button" data-about-review-scroll="next" aria-label="Next review">
				&rarr;
			</button>
		</div>
	</section>

	<script>
		const aboutReviewsTrack = document.querySelector('#about-reviews-track');
		const aboutReviewButtons = document.querySelectorAll('[data-about-review-scroll]');

		const getAboutReviewMaxScroll = () => {
			if (!(aboutReviewsTrack instanceof HTMLElement)) return 0;

			return Math.max(aboutReviewsTrack.scrollWidth - aboutReviewsTrack.clientWidth, 0);
		};

		const updateAboutReviewControls = () => {
			if (!(aboutReviewsTrack instanceof HTMLElement)) return;

			const maxScroll = getAboutReviewMaxScroll();
			const atStart = aboutReviewsTrack.scrollLeft <= 1;
			const atEnd = maxScroll - aboutReviewsTrack.scrollLeft <= 1;

			aboutReviewButtons.forEach((button) => {
				if (!(button instanceof HTMLButtonElement)) return;

				const direction = button.getAttribute('data-about-review-scroll');
				button.disabled = direction === 'prev' ? atStart : atEnd;
			});
		};

		aboutReviewButtons.forEach((button) => {
			button.addEventListener('click', () => {
				if (!(aboutReviewsTrack instanceof HTMLElement)) return;
				if (!(button instanceof HTMLButtonElement) || button.disabled) return;

				const direction = button.getAttribute('data-about-review-scroll') === 'next' ? 1 : -1;
				const distance = aboutReviewsTrack.clientWidth * 0.72;
				const maxScroll = getAboutReviewMaxScroll();
				const nextScroll = Math.min(
					Math.max(aboutReviewsTrack.scrollLeft + distance * direction, 0),
					maxScroll,
				);

				aboutReviewsTrack.scrollTo({
					left: nextScroll,
					behavior: 'smooth',
				});
			});
		});

		if (aboutReviewsTrack instanceof HTMLElement) {
			aboutReviewsTrack.addEventListener('scroll', updateAboutReviewControls, { passive: true });
			window.addEventListener('resize', updateAboutReviewControls);
			updateAboutReviewControls();
		}
	</script>

	<section class="about-cta-band" aria-label="Next steps">
		{ctaBandImage && (
			<img
				class="about-cta-band__image"
				src={ctaBandImage}
				alt=""
				loading="lazy"
				decoding="async"
			/>
		)}

		<div class="about-cta-band__cards">
			{page?.ctaCards?.map((card: any) => (
				<AboutCtaCard
					href={card.buttonLink}
					label={card.buttonLabel}
					title={card.title}
					text={card.text}
				/>
			))}
		</div>
	</section>
</SiteLayout>
