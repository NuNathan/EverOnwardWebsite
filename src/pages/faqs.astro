---
import AccordionItem from '../components/AccordionItem.astro';
import CtaBanner from '../components/CtaBanner.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { fetchStrapi, strapiMediaUrl } from '../lib/strapi';
import '../styles/cta.css';
import '../styles/faqs.css';

const { data: page } = await fetchStrapi('/faq-page', {
	populate: 'heroImage,faqItems,ctaBackgroundImage',
});

const heroImage = strapiMediaUrl(page?.heroImage?.url);
const ctaBackground = strapiMediaUrl(page?.ctaBackgroundImage?.url);
---

<SiteLayout
	title="FAQ | Ever Onward Canine"
	description="Frequently asked questions for Ever Onward Canine."
>
	<section class="faq-hero" aria-labelledby="faq-hero-title">
		<div class="faq-hero__frame">
			<img
				class="faq-hero__image"
				src={heroImage}
				alt=""
				loading="eager"
				decoding="async"
			/>

			<div class="faq-hero__overlay">
				<div class="faq-hero__content">
					<p>{page?.heroEyebrow}</p>
					<h1 id="faq-hero-title">{page?.heroHeading}</h1>
				</div>
			</div>
		</div>
	</section>

	<section class="faq-list" aria-label="Frequently asked questions">
		<div class="faq-list__inner">
			{page?.faqItems?.map((item: any, index: number) => (
				<AccordionItem
					itemClass="faq-item"
					contentClass="faq-item__content"
					summary={item.question}
					open={index === 0}
				>
					<p>{item.answer}</p>
				</AccordionItem>
			))}
		</div>
	</section>

	<CtaBanner
		id="faq-cta-title"
		title={page?.ctaHeading || ''}
		imageSrc={ctaBackground}
		eyebrow={page?.ctaEyebrow}
		buttonHref={page?.ctaButtonLink}
		buttonText={page?.ctaButtonText}
	/>
</SiteLayout>
