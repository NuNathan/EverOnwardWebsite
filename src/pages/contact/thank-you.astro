---
import SiteLayout from '../../layouts/SiteLayout.astro';
import '../../styles/contact.css';
---

<SiteLayout
	title="Thank You | Ever Onward Canine"
	description="Your message has been received."
>
	<section class="contact-hero" aria-labelledby="thank-you-title">
		<div class="contact-hero__content" style="padding: 6rem 2rem; text-align: center;">
			<h1 id="thank-you-title">Thank You!</h1>
			<p style="max-width: 40rem; margin: 1.5rem auto 2rem;">
				Your message has been received. I'll be in touch within 48 hours. Be sure to check
				your junk or spam folder just in case my reply lands there.
			</p>
			<a class="button-link" href="/">Back to Home</a>
		</div>
	</section>
</SiteLayout>
