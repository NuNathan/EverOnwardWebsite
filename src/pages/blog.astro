---
import BlogPostCard from '../components/BlogPostCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import { fetchStrapi, strapiMediaUrl } from '../lib/strapi';
import '../styles/blog.css';

const { data: blogPage } = await fetchStrapi('/blog-page', { populate: 'heroImage' });
const { data: posts } = await fetchStrapi('/blog-posts', {
	populate: 'coverImage',
	sort: 'publishedDate:desc',
});

const heroImage = strapiMediaUrl(blogPage?.heroImage?.url);
---

<SiteLayout
	title="Blog | Ever Onward Canine"
	description="Read the Ever Onward Canine blog."
>
	<section class="blog-hero" aria-labelledby="blog-hero-title">
		<img
			class="blog-hero__image"
			src={heroImage}
			alt=""
			loading="eager"
			decoding="async"
		/>

		<div class="blog-hero__content">
			<h1 id="blog-hero-title">{blogPage?.heroHeading || 'The Blog'}</h1>
			<img
				class="blog-hero__paw"
				src="/images/general/Paw.webp"
				alt=""
				loading="eager"
				decoding="async"
			/>
		</div>
	</section>

	<section class="blog-posts" aria-label="Blog posts">
		{(posts as any[])?.map((post: any) => {
			const date = new Date(post.publishedDate);
			const formatted = `${date.getMonth() + 1}/${date.getDate()}/${String(date.getFullYear()).slice(2)}`;

			return (
				<BlogPostCard
					title={post.title}
					date={formatted}
					datetime={post.publishedDate}
					excerpt={post.excerpt || ''}
					href={`/blog/${post.slug}`}
					imageSrc={strapiMediaUrl(post.coverImage?.url)}
					imageAlt={post.coverImageAlt || ''}
				/>
			);
		})}
	</section>
</SiteLayout>
