---
import BlogPostCard from '../components/BlogPostCard.astro';
import SiteLayout from '../layouts/SiteLayout.astro';
import '../styles/blog.css';

const posts = [
	{
		title: 'Sample Blog Post Two',
		date: '4/9/26',
		datetime: '2026-04-09',
		excerpt:
			'Ut non enim eleifend felis pretium feugiat. Donec pede justo, fringilla vel, aliquet nec, vulputate eget, arcu.',
		href: '/blog/sample-blog-post-two',
		imageSrc: '/images/home/pexels-helenalopes-27176300.webp',
		imageAlt: 'Brown dog resting with a person.',
	},
	{
		title: 'Sample Blog Post One',
		date: '4/1/26',
		datetime: '2026-04-01',
		excerpt:
			'Ut non enim eleifend felis pretium feugiat. Donec pede justo, fringilla vel, aliquet nec, vulputate eget, arcu.',
		href: '/blog/sample-blog-post-one',
		imageSrc: '/images/home/jack-russel-terrier-puppy-2W8VNP6.webp',
		imageAlt: 'Jack Russell terrier puppy resting in white bedding.',
	},
];
---

<SiteLayout
	title="Blog | Ever Onward Canine"
	description="Read the Ever Onward Canine blog."
>
	<section class="blog-hero" aria-labelledby="blog-hero-title">
		<img
			class="blog-hero__image"
			src="/images/general/AdobeStock_581231653.webp"
			alt=""
			loading="eager"
			decoding="async"
		/>

		<div class="blog-hero__content">
			<h1 id="blog-hero-title">The Blog</h1>
			<img
				class="blog-hero__paw"
				src="/images/general/Paw.webp"
				alt=""
				loading="eager"
				decoding="async"
			/>
		</div>
	</section>

	<section class="blog-posts" aria-label="Blog posts">
		{posts.map((post) => <BlogPostCard {...post} />)}
	</section>
</SiteLayout>
