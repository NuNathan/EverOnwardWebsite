---
import SiteLayout from '../layouts/SiteLayout.astro';
import '../styles/contact.css';
---

<SiteLayout
	title="Contact | Ever Onward Canine"
	description="Contact Ever Onward Canine to get started with dog training."
>
	<section class="contact-hero" aria-labelledby="contact-hero-title">
		<img
			class="contact-hero__image"
			src="/images/general/AdobeStock_581231653.webp"
			alt=""
			loading="eager"
			decoding="async"
		/>

		<div class="contact-hero__content">
			<h1 id="contact-hero-title">
				Let&rsquo;s work together to bring out the best in your pup&mdash;and give you the tools
				to lead with confidence. I can&rsquo;t wait to connect with you.
			</h1>
		</div>

		<div class="contact-hero__bar" aria-hidden="true"></div>
	</section>

	<section class="contact-form-section" aria-labelledby="contact-form-title">
		<div class="contact-form-section__media">
			<div class="contact-form-section__image-wrap">
				<img
					class="contact-form-section__image"
					src="/images/contact/pexels-karola-g-5426878.webp"
					alt="Husky sitting beside a person indoors."
					loading="lazy"
					decoding="async"
				/>

				<img
					class="contact-form-section__submark"
					src="/images/general/Submark-B-White.webp"
					alt=""
					loading="lazy"
					decoding="async"
				/>
			</div>

			<div class="contact-form-section__details">
				<p>Christina Campbell, <em>Owner, Coach &amp; Trainer</em></p>
				<p><em>Location Information</em></p>
				<p><em>Contact Information</em></p>
			</div>
		</div>

		<form class="contact-form" action="/contact" method="post">
			<fieldset class="contact-form__fieldset">
				<legend id="contact-form-title">Name</legend>
				<div class="contact-form__name-grid">
					<label>
						<span>First Name <small>(required)</small></span>
						<input type="text" name="first-name" autocomplete="given-name" required />
					</label>
					<label>
						<span>Last Name <small>(required)</small></span>
						<input type="text" name="last-name" autocomplete="family-name" required />
					</label>
				</div>
			</fieldset>

			<label>
				<span>Email <small>(required)</small></span>
				<input type="email" name="email" autocomplete="email" required />
			</label>

			<label>
				<span>Phone</span>
				<input type="tel" name="phone" autocomplete="tel" />
			</label>

			<label>
				<span>Location <small>(required)</small></span>
				<textarea name="location" rows="5" required></textarea>
			</label>

			<label>
				<span>Dog&rsquo;s Name, Breed and Age <small>(required)</small></span>
				<textarea name="dog-details" rows="5" required></textarea>
			</label>

			<label>
				<span>
					Briefly describe the challenges and / or goals you have with your dog
					<small>(required)</small>
				</span>
				<textarea name="goals" rows="5" required></textarea>
			</label>

			<label>
				<span>Which services are you interested in?</span>
				<select name="service-interest">
					<option value="">Select an option</option>
					<option value="virtual-training">Virtual training</option>
					<option value="puppy-foundations">Puppy foundations</option>
					<option value="behavior-consultation">Behavior consultation</option>
				</select>
			</label>

			<label>
				<span>How did you hear about us? <small>(required)</small></span>
				<input type="text" name="referral-source" required />
			</label>

			<button class="contact-form__submit" type="submit">Submit</button>
		</form>
	</section>
</SiteLayout>
