---
import SiteLayout from '../layouts/SiteLayout.astro';
import { fetchStrapi, strapiMediaUrl } from '../lib/strapi';
import '../styles/contact.css';

const { data: page } = await fetchStrapi('/contact-page', {
	populate: 'heroImage,contactImage,serviceOptions',
});

const heroImage = strapiMediaUrl(page?.heroImage?.url);
const contactImage = strapiMediaUrl(page?.contactImage?.url);
---

<SiteLayout
	title="Contact | Ever Onward Canine"
	description="Contact Ever Onward Canine to get started with dog training."
>
	<section class="contact-hero" aria-labelledby="contact-hero-title">
		<img
			class="contact-hero__image"
			src={heroImage}
			alt=""
			loading="eager"
			decoding="async"
		/>

		<div class="contact-hero__content">
			<h1 id="contact-hero-title">{page?.heroHeading}</h1>
		</div>

		<div class="contact-hero__bar" aria-hidden="true"></div>
	</section>

	<section class="contact-form-section" aria-labelledby="contact-form-title">
		<div class="contact-form-section__media">
			<div class="contact-form-section__image-wrap">
				{contactImage && (
					<img
						class="contact-form-section__image"
						src={contactImage}
						alt=""
						loading="lazy"
						decoding="async"
					/>
				)}

				<img
					class="contact-form-section__submark"
					src="/images/general/Submark-B-White.webp"
					alt=""
					loading="lazy"
					decoding="async"
				/>
			</div>

			<div class="contact-form-section__details">
				{page?.contactName && <p>{page.contactName}{page?.contactTitle ? `, ${page.contactTitle}` : ''}</p>}
				{page?.contactLocation && <p><em>{page.contactLocation}</em></p>}
				{page?.contactInfo && <p><em>{page.contactInfo}</em></p>}
			</div>
		</div>

		<form class="contact-form" id="contact-form">
			<fieldset class="contact-form__fieldset">
				<legend id="contact-form-title">Name</legend>
				<div class="contact-form__name-grid">
					<label>
						<span>First Name <small>(required)</small></span>
						<input type="text" name="firstName" autocomplete="given-name" required />
					</label>
					<label>
						<span>Last Name <small>(required)</small></span>
						<input type="text" name="lastName" autocomplete="family-name" required />
					</label>
				</div>
			</fieldset>

			<label>
				<span>Email <small>(required)</small></span>
				<input type="email" name="email" autocomplete="email" required />
			</label>

			<label>
				<span>Phone</span>
				<input type="tel" name="phone" autocomplete="tel" />
			</label>

			<label>
				<span>Location</span>
				<textarea name="location" rows="5"></textarea>
			</label>

			<label>
				<span>Dog&rsquo;s Name, Breed and Age</span>
				<textarea name="dogDetails" rows="5"></textarea>
			</label>

			<label>
				<span>
					Briefly describe the challenges and / or goals you have with your dog
				</span>
				<textarea name="goals" rows="5"></textarea>
			</label>

			<label>
				<span>Which services are you interested in?</span>
				<select name="serviceInterest">
					<option value="">Select an option</option>
					{page?.serviceOptions?.map((opt: any) => (
						<option value={opt.value}>{opt.label}</option>
					))}
				</select>
			</label>

			<label>
				<span>How did you hear about us?</span>
				<input type="text" name="referralSource" />
			</label>

			<button class="contact-form__submit" type="submit">Submit</button>
		</form>
	</section>

	<script>
		const contactForm = document.getElementById('contact-form');
		contactForm?.addEventListener('submit', async (e) => {
			e.preventDefault();
			const form = e.target as HTMLFormElement;
			const formData = new FormData(form);
			const body = Object.fromEntries(formData.entries());

			try {
				const res = await fetch(`${import.meta.env.PUBLIC_STRAPI_URL || ''}/api/contact-submissions`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(body),
				});
				if (res.ok) {
					window.location.href = '/contact/thank-you';
				} else {
					alert('Something went wrong. Please try again.');
				}
			} catch {
				alert('Something went wrong. Please try again.');
			}
		});
	</script>
</SiteLayout>
