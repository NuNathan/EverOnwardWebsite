---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import '../styles/layout.css';
import { fetchStrapi, strapiMediaUrl } from '../lib/strapi';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Ever Onward Canine',
	description = 'Ever Onward Canine static website.',
} = Astro.props;

const { data: settings } = await fetchStrapi('/site-settings', { populate: '*' });

const headerLogo = strapiMediaUrl(settings?.headerLogo?.url);
const footerLogo = strapiMediaUrl(settings?.footerLogo?.url);
const headerButtonText = settings?.headerButtonText || 'Get Started';
const headerButtonLink = settings?.headerButtonLink || '/contact';
const email = settings?.email || '';
const phone = settings?.phone || '';
const facebookUrl = settings?.facebookUrl || '';
const instagramUrl = settings?.instagramUrl || '';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600&family=Poppins:wght@300;400;500;600&display=swap"
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell">
			<Header
				logoSrc={headerLogo}
				buttonText={headerButtonText}
				buttonLink={headerButtonLink}
				email={email}
				facebookUrl={facebookUrl}
				instagramUrl={instagramUrl}
			/>
			<main class="site-main">
				<slot />
			</main>
			<Footer
				logoSrc={footerLogo}
				email={email}
				phone={phone}
				facebookUrl={facebookUrl}
				instagramUrl={instagramUrl}
			/>
		</div>
	</body>
</html>
